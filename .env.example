# Upstream LLM provider (proxied)
RAGFW_UPSTREAM_BASE_URL=https://api.openai.com
RAGFW_UPSTREAM_API_KEY=sk-replace-me

# Server
RAGFW_HOST=0.0.0.0
RAGFW_PORT=8080
RAGFW_LOG_LEVEL=INFO

# Policy toggles
RAGFW_ENABLE_INPUT_SCANNER=true
RAGFW_ENABLE_OUTPUT_SCANNER=true
RAGFW_ENABLE_TOOL_ALLOWLIST=true

# Defense thresholds (0.0-1.0)
RAGFW_INJECTION_THRESHOLD=0.6

# Comma-separated list of allowed tool names (empty = allow all)
RAGFW_TOOL_ALLOWLIST=

# Telemetry
RAGFW_OTEL_EXPORTER_OTLP_ENDPOINT=
RAGFW_SERVICE_NAME=rag-firewall
